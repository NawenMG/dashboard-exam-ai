# =========================
# APP
# =========================
APP_NAME="FastAPI Project"
ENVIRONMENT=dev
DEBUG=true


# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql+asyncpg://yugabyte:yugabyte@yb1:5433/yugabyte


# =========================
# JWT / EdDSA
# =========================
JWT_ALG=EdDSA
JWT_ISSUER=fastapi-exam-dashboard
JWT_AUDIENCE=fastapi-exam-dashboard
ACCESS_TOKEN_EXPIRE_MINUTES=60

JWT_PRIVATE_KEY_PATH=keys/ed25519_private.pem
JWT_PUBLIC_KEY_PATH=keys/ed25519_public.pem

MOCK_AUTH_FALLBACK_TEACHER=false


# =========================
# OLLAMA
# =========================
# Base URL (dentro Docker usa host.docker.internal o nome servizio)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Modello per grading
OLLAMA_MODEL=llama3.1:8b

# Modello embeddings (IMPORTANTE)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Endpoint override (opzionali)
OLLAMA_GENERATE_PATH=/api/generate
OLLAMA_EMBEDDINGS_PATH=/api/embeddings


# =========================
# QDRANT
# =========================
QDRANT_URL=http://qdrant:6333
QDRANT_GRPC_URL=http://qdrant:6334

# Nome collection per RAG
QDRANT_COLLECTION=exam_material_chunks


# =========================
# RAG CONFIG
# =========================
# Dimensione chunk in parole (MVP)
RAG_CHUNK_WORDS=220

# Overlap parole
RAG_CHUNK_OVERLAP=40

# Numero chunk da recuperare in retrieval (step successivo)
RAG_TOP_K=8
