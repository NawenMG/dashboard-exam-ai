APP_NAME="FastAPI Project"
ENVIRONMENT=dev
DEBUG=true

# --- MariaDB ---
MARIADB_ROOT_PASSWORD=change_me_root
MARIADB_DATABASE=fastapi_db
MARIADB_USER=fastapi_user
MARIADB_PASSWORD=change_me_user
MARIADB_PORT=3306

DATABASE_URL=mysql+pymysql://fastapi_user:change_me_user@127.0.0.1:3306/fastapi_db


# --- JWT / EdDSA ---
JWT_ALG=EdDSA
JWT_ISSUER=fastapi-exam-dashboard
JWT_AUDIENCE=fastapi-exam-dashboard
ACCESS_TOKEN_EXPIRE_MINUTES=60

# percorsi chiavi Ed25519
JWT_PRIVATE_KEY_PATH=keys/ed25519_private.pem
JWT_PUBLIC_KEY_PATH=keys/ed25519_public.pem


# --- Mock auth fallback (solo dev) ---
MOCK_AUTH_FALLBACK_TEACHER=false
